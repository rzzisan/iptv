[Unit]
Description=Live TV Channel Relay (%i)
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=www-data
Group=www-data
ExecStart=/opt/livetv/channel-stream.sh %i
Restart=always
RestartSec=3
KillSignal=SIGTERM
TimeoutStopSec=10
LimitNOFILE=65536
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
